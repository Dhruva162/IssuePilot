# A token raises GitHub's rate limit from 60 to 5,000 requests/hour.
GITHUB_TOKEN=
ISSUEPILOT_DATABASE_URL=sqlite:///./data/issuepilot.db
ISSUEPILOT_WORKSPACE=./workspaces
ISSUEPILOT_TASKS_DIR=./tasks
ISSUEPILOT_MAX_ISSUES=10
ISSUEPILOT_MIN_STARS=100
ISSUEPILOT_MAX_REPO_SIZE_KB=500000
ISSUEPILOT_GITHUB_QUERY=is:issue is:open label:"good first issue" archived:false
ISSUEPILOT_LOG_LEVEL=INFO
ISSUEPILOT_FRONTEND_URL=http://localhost:5173
ISSUEPILOT_API_URL=http://127.0.0.1:8000

